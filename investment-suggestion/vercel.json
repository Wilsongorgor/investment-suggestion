{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/stock/(data|analyze)",
      "methods": ["POST"],
      "dest": "/api/stock/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/stock/data": {
      "maxDuration": 60
    },
    "api/stock/analyze": {
      "maxDuration": 60
    }
  }
}